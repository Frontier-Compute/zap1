{
  "suite": "ZAP1 Memo Conformance",
  "version": "1.0.0",
  "spec": "https://github.com/Frontier-Compute/zap1/blob/main/ONCHAIN_PROTOCOL.md",
  "pattern": "^(ZAP1|NSM1):([0-9a-fA-F]{2}):([0-9a-fA-F]{64})$",
  "notes": "Type hex is normalized to lowercase after capture.  Agent types 0x40-0x45 are valid ZAP1 memos but wallet parsers may not have labels for them.  expected_event_name uses TYPE_0x{hex} for types not in the base 15 lookup table.",
  "vectors": [
    {
      "id": "valid_01_program_entry",
      "input": "ZAP1:01:075b00df286038a7b3f6bb70054df61343e3481fba579591354a00214e9e019b",
      "expected_parse": true,
      "expected_prefix": "ZAP1",
      "expected_type_hex": "01",
      "expected_event_name": "PROGRAM_ENTRY",
      "expected_hash": "075b00df286038a7b3f6bb70054df61343e3481fba579591354a00214e9e019b",
      "expected_short_hash": "075b00df2860...",
      "expected_is_legacy": false,
      "description": "Valid program entry - real mainnet leaf from first attestation tree"
    },
    {
      "id": "valid_02_ownership_attest",
      "input": "ZAP1:02:a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2",
      "expected_parse": true,
      "expected_prefix": "ZAP1",
      "expected_type_hex": "02",
      "expected_event_name": "OWNERSHIP_ATTEST",
      "expected_hash": "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2",
      "expected_short_hash": "a1b2c3d4e5f6...",
      "expected_is_legacy": false,
      "description": "Valid ownership attestation"
    },
    {
